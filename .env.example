# ==========================================================================
# mcpgate AI Gateway — Environment Configuration
# ==========================================================================
# Copy this file to .env and fill in your values.
# All variables without a default are REQUIRED.
# Variables with a default value are optional.
#
# Documentation: https://mcpgate.de/docs (coming soon)
# ==========================================================================

# ==========================================================================
# CORE — Required for basic operation
# ==========================================================================

# Base URL where the gateway is accessible (used for OAuth callbacks)
BASE_URL=https://ai-gateway.yourcompany.com

# Admin users who can access /admin dashboard (comma-separated emails)
ADMIN_USERS=admin@yourcompany.com

# Company email domains for authentication (comma-separated)
# Users with these domains can sign in via Google OAuth
COMPANY_DOMAINS=@yourcompany.com

# ==========================================================================
# SECURITY — Required
# ==========================================================================

# JWT secret for session tokens (generate: openssl rand -hex 32)
JWT_SECRET=

# Encryption key for stored OAuth tokens
# Option A: Fernet key (generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Option B: GCP KMS (recommended for production)
# GCP_KMS_KEY_NAME=projects/YOUR_PROJECT/locations/YOUR_REGION/keyRings/YOUR_RING/cryptoKeys/YOUR_KEY
# GCP_KMS_CREDENTIALS=<base64-encoded service account JSON>

# ==========================================================================
# REDIS — Required
# ==========================================================================

REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=

# ==========================================================================
# AI PROVIDERS — At least one required
# ==========================================================================

# Anthropic (for Claude integration)
ANTHROPIC_API_KEY=

# OpenAI (for ChatGPT integration)
# OPENAI_API_KEY=

# ChatGPT Custom GPT OAuth (if using ChatGPT Actions)
# CHATGPT_CLIENT_ID=
# CHATGPT_CLIENT_SECRET=

# ==========================================================================
# GOOGLE WORKSPACE — Gmail, Calendar, Drive, Docs, Sheets, Slides
# ==========================================================================
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: ${BASE_URL}/auth/callback

# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=

# ==========================================================================
# SLACK
# ==========================================================================
# Create a Slack App at https://api.slack.com/apps
# Bot token scopes: channels:history, channels:read, chat:write, search:read, users:read, users:read.email

# SLACK_BOT_TOKEN=
# SLACK_SIGNING_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_TEAM_ID=

# ==========================================================================
# JIRA
# ==========================================================================
# Create OAuth 2.0 (3LO) app at https://developer.atlassian.com/console/myapps/
# Redirect URI: ${BASE_URL}/auth/jira/callback

# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=

# ==========================================================================
# GITLAB
# ==========================================================================
# Create OAuth application in GitLab Admin → Applications
# Redirect URI: ${BASE_URL}/auth/gitlab/callback
# Scopes: api, read_user

# GITLAB_OAUTH_CLIENT_ID=
# GITLAB_OAUTH_CLIENT_SECRET=

# GitLab instance URL (for self-hosted GitLab)
# GITLAB_BASE_URL=https://gitlab.com

# GitLab API token for issue management / self-healing (optional)
# GITLAB_TOKEN=
# GITLAB_ISSUE_TOKEN=

# ==========================================================================
# NOTION
# ==========================================================================
# Create internal integration at https://www.notion.so/my-integrations
# Redirect URI: ${BASE_URL}/auth/notion/callback

# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=

# ==========================================================================
# FIGMA
# ==========================================================================
# Create OAuth app in Figma account settings
# Redirect URI: ${BASE_URL}/auth/figma/callback

# FIGMA_OAUTH_CLIENT_ID=
# FIGMA_OAUTH_CLIENT_SECRET=

# ==========================================================================
# GRAFANA — Dashboards, Logs, Metrics
# ==========================================================================

# GRAFANA_URL=https://grafana.yourcompany.com
# GRAFANA_API_KEY=

# ==========================================================================
# AMPLITUDE — Product Analytics
# ==========================================================================

# AMPLITUDE_API_KEY=
# AMPLITUDE_SECRET_KEY=

# ==========================================================================
# SENTRY — Error Tracking
# ==========================================================================

# SENTRY_AUTH_TOKEN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ==========================================================================
# METABASE — BI / Data Warehouse
# ==========================================================================
# Uses Google OAuth for authentication

# METABASE_GOOGLE_CLIENT_ID=
# METABASE_GOOGLE_CLIENT_SECRET=

# ==========================================================================
# HOME ASSISTANT — Office Automation (optional)
# ==========================================================================

# HOME_ASSISTANT_URL=
# HOME_ASSISTANT_ACCESS_TOKEN=

# ==========================================================================
# JOAN — Desk & Room Booking (optional)
# ==========================================================================

# JOAN_API_KEY=
# JOAN_API_SECRET=
# JOAN_API_URL=

# ==========================================================================
# APP STORE / GOOGLE PLAY — Mobile Release Monitoring (optional)
# ==========================================================================

# ASC_KEY_ID=
# ASC_ISSUER_ID=
# ASC_KEY_CONTENT=
# GOOGLE_PLAY_CREDENTIALS=

# ==========================================================================
# ADVANCED — Usually fine with defaults
# ==========================================================================

# Server ports (change if you have conflicts)
MCP_SERVER_PORT=3000
OAUTH_PORT=3001

# Environment name (affects logging, debug mode, CORS)
# ENVIRONMENT=production

# Log level
# LOG_LEVEL=info

# Enable Swagger UI at /docs (disable in production)
# ENABLE_SWAGGER=false

# System email for automated notifications
# SYSTEM_EMAIL=noreply@yourcompany.com

# Webhook secrets (for GitLab/deployment webhooks)
# GITLAB_WEBHOOK_SECRET=
# DEPLOYMENT_WEBHOOK_SECRET=
