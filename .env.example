# ==========================================================================
# mcpgate AI Gateway — Environment Configuration
# ==========================================================================
#
# Copy this file to .env and fill in your values.
#
# HOW THIS WORKS:
# - Uncomment a line and set a value to enable a feature/service
# - Services only activate when their credentials are provided
# - The gateway works with as few as 1 service connected
#
# WHAT YOU NEED AT MINIMUM:
# 1. BASE_URL        — where the gateway runs
# 2. ADMIN_USERS     — who can access the admin dashboard
# 3. COMPANY_DOMAINS — which email domains can sign in
# 4. JWT_SECRET      — generate with: openssl rand -hex 32
# 5. ENCRYPTION_KEY  — generate with: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 6. REDIS_PASSWORD  — pick any strong password
# 7. At least one service (e.g. Google Workspace or Slack)
#
# ==========================================================================


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  CORE — Required                                                      ║
# ╚════════════════════════════════════════════════════════════════════════╝

# Public URL where the gateway is accessible.
# Used for OAuth callback URLs and MCP endpoint.
# Example: https://ai-gateway.yourcompany.com
BASE_URL=

# Who can access the /admin dashboard and /connections page.
# Comma-separated email addresses.
ADMIN_USERS=

# Which email domains are allowed to sign in via Google OAuth.
# Comma-separated, with @ prefix.
# Example: @yourcompany.com,@subsidiary.com
COMPANY_DOMAINS=


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  SECURITY — Required                                                  ║
# ╚════════════════════════════════════════════════════════════════════════╝

# Session token signing key.
# Generate: openssl rand -hex 32
JWT_SECRET=

# Encryption key for stored OAuth tokens.
# Generate: python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=

# For stronger security: use your own GCP KMS key instead of Fernet.
# You control the key — revoke it and all tokens become unreadable.
# GCP_KMS_KEY_NAME=projects/YOUR_PROJECT/locations/YOUR_REGION/keyRings/YOUR_RING/cryptoKeys/YOUR_KEY
# GCP_KMS_CREDENTIALS=<base64-encoded service account JSON>


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  REDIS — Required                                                     ║
# ╚════════════════════════════════════════════════════════════════════════╝

# If using the included docker-compose.yaml, keep the URL as-is.
# Only change REDIS_PASSWORD.
REDIS_URL=redis://redis:6379/0
REDIS_PASSWORD=


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  SERVICES — Enable by uncommenting and filling in credentials          ║
# ║                                                                        ║
# ║  Each service is independent. Enable only what you need.               ║
# ║  The gateway auto-detects which services are configured.               ║
# ╚════════════════════════════════════════════════════════════════════════╝


# ── Google Workspace (Gmail, Calendar, Drive, Docs, Sheets, Slides) ──────
#
# 1. Go to https://console.cloud.google.com/apis/credentials
# 2. Create OAuth 2.0 Client ID (Web Application)
# 3. Add authorized redirect URI: <BASE_URL>/auth/callback
# 4. Enable the APIs you need (Gmail, Calendar, Drive, Docs, Sheets)
#
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=


# ── Slack ────────────────────────────────────────────────────────────────
#
# 1. Create a Slack App at https://api.slack.com/apps
# 2. Add bot token scopes: channels:history, channels:read, chat:write,
#    search:read, users:read, users:read.email
# 3. Install to your workspace
#
# SLACK_BOT_TOKEN=xoxb-...
# SLACK_SIGNING_SECRET=
# SLACK_CLIENT_ID=
# SLACK_CLIENT_SECRET=
# SLACK_TEAM_ID=


# ── Jira ─────────────────────────────────────────────────────────────────
#
# 1. Go to https://developer.atlassian.com/console/myapps/
# 2. Create OAuth 2.0 (3LO) app
# 3. Add callback URL: <BASE_URL>/auth/jira/callback
# 4. Add scopes: read:jira-work, write:jira-work, read:jira-user
#
# JIRA_OAUTH_CLIENT_ID=
# JIRA_OAUTH_CLIENT_SECRET=
# JIRA_BASE_URL=https://yourcompany.atlassian.net


# ── GitLab ───────────────────────────────────────────────────────────────
#
# 1. In GitLab: Admin → Applications (or User Settings → Applications)
# 2. Create OAuth application
# 3. Redirect URI: <BASE_URL>/auth/gitlab/callback
# 4. Scopes: api, read_user
#
# GITLAB_OAUTH_CLIENT_ID=
# GITLAB_OAUTH_CLIENT_SECRET=
# GITLAB_BASE_URL=https://gitlab.com


# ── Notion ───────────────────────────────────────────────────────────────
#
# 1. Go to https://www.notion.so/my-integrations
# 2. Create internal integration
# 3. Share relevant pages/databases with the integration
#
# NOTION_OAUTH_CLIENT_ID=
# NOTION_OAUTH_CLIENT_SECRET=


# ── Figma ────────────────────────────────────────────────────────────────
#
# 1. Figma account settings → create OAuth app
# 2. Redirect URI: <BASE_URL>/auth/figma/callback
#
# FIGMA_OAUTH_CLIENT_ID=
# FIGMA_OAUTH_CLIENT_SECRET=


# ── Grafana (Dashboards, Logs, Metrics) ──────────────────────────────────
#
# 1. Create a Service Account in Grafana
# 2. Generate API key with viewer role (or editor if you want write access)
#
# GRAFANA_URL=https://grafana.yourcompany.com
# GRAFANA_API_KEY=


# ── Amplitude (Product Analytics) ────────────────────────────────────────
#
# Settings → Projects → select project → API credentials
#
# AMPLITUDE_API_KEY=
# AMPLITUDE_SECRET_KEY=


# ── Sentry (Error Tracking) ─────────────────────────────────────────────
#
# User settings → Auth Tokens → create token
#
# SENTRY_AUTH_TOKEN=
# SENTRY_BASE_URL=https://sentry.io/api/0
# SENTRY_ORG=
# SENTRY_PROJECT=


# ── Metabase (BI / Data Warehouse) ──────────────────────────────────────
#
# Uses Google OAuth for user authentication.
# Create a separate OAuth client for Metabase in Google Cloud Console.
#
# METABASE_URL=https://metabase.yourcompany.com
# METABASE_GOOGLE_CLIENT_ID=
# METABASE_GOOGLE_CLIENT_SECRET=


# ── Jenkins (CI/CD) ─────────────────────────────────────────────────────
#
# JENKINS_URL=https://jenkins.yourcompany.com


# ── Home Assistant (Office Sensors & Heating) ────────────────────────────
#
# User profile → Long-Lived Access Token
#
# HOME_ASSISTANT_URL=
# HOME_ASSISTANT_ACCESS_TOKEN=


# ── Joan (Desk & Meeting Room Booking) ───────────────────────────────────
#
# JOAN_API_KEY=
# JOAN_API_SECRET=
# JOAN_API_URL=


# ── App Store Connect & Google Play (Mobile Release Monitoring) ──────────
#
# ASC_KEY_ID=
# ASC_ISSUER_ID=
# ASC_KEY_CONTENT=
# GOOGLE_PLAY_CREDENTIALS=


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  AI FEATURES — Optional, requires an AI provider API key              ║
# ║                                                                        ║
# ║  These enable advanced features like self-healing (automatic error     ║
# ║  detection and issue creation) and prototype mode (AI builds UIs).     ║
# ║  The core gateway (tool access + hooks) works WITHOUT these.           ║
# ╚════════════════════════════════════════════════════════════════════════╝

# Anthropic Claude API key
# Enables: self-healing, prototype mode, smart routing fallback
# ANTHROPIC_API_KEY=

# OpenAI API key (alternative to Anthropic)
# OPENAI_API_KEY=

# ChatGPT Custom GPT integration (if using ChatGPT Actions)
# CHATGPT_CLIENT_ID=
# CHATGPT_CLIENT_SECRET=


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  ERROR REPORTING — Optional                                            ║
# ║                                                                        ║
# ║  When enabled, the gateway automatically reports errors back to        ║
# ║  mcpgate. We fix them and ship an updated image. You just pull.        ║
# ╚════════════════════════════════════════════════════════════════════════╝

# MCPGATE_ISSUE_TOKEN=<provided during onboarding>
# MCPGATE_ISSUE_URL=https://gitlab.com
# MCPGATE_ISSUE_PROJECT=mcpgate/issues


# ╔════════════════════════════════════════════════════════════════════════╗
# ║  ADVANCED — Usually fine with defaults                                 ║
# ╚════════════════════════════════════════════════════════════════════════╝

# Server ports (change if you have conflicts)
MCP_SERVER_PORT=3000
OAUTH_PORT=3001

# Environment name (affects logging, debug mode, CORS)
# ENVIRONMENT=production

# Log level: debug, info, warning, error
# LOG_LEVEL=info

# Swagger UI at /docs (useful for testing, disable in production)
# ENABLE_SWAGGER=false

# Sender address for automated email notifications
# SYSTEM_EMAIL=noreply@yourcompany.com

# Timezone for date formatting in responses
# DEFAULT_TIMEZONE=Europe/Berlin
